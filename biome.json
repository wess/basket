{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off"
      },
      "style": {
        "noNonNullAssertion": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "overrides": [
    {
      "includes": ["packages/ui/**/*.tsx"],
      "linter": {
        "rules": {
          "a11y": {
            "noStaticElementInteractions": "off",
            "useKeyWithClickEvents": "off"
          },
          "security": {
            "noDangerouslySetInnerHtml": "off"
          }
        }
      }
    }
  ],
  "files": {
    "includes": [
      "packages/**/*.ts",
      "packages/**/*.tsx",
      "example/**/*.ts",
      "example/**/*.tsx",
      "!**/node_modules/**",
      "!**/dist/**",
      "!**/build/**",
      "!**/*.d.ts"
    ]
  }
}
